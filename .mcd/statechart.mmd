    idle_running --> idle_running: STOP_TIMER_NO_OPEN / reconcileNoOpenSession (StopTimerInput -> NoOpenSessionError)
    idle_running --> error_storage_write: STOP_TIMER_STORAGE_FAIL / retryOrKeepOpen (StopTimerInput -> StorageWriteError)

    idle_running --> idle_paused: PAUSE_TIMER / pauseSessionOnTask (StopTimerInput -> Task)
